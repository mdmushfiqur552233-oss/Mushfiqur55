            display: flex; justify-content: space-around; padding: 15px; z-index: 100;
        }
        .nav-icon { font-size: 22px; color: #b2bec3; transition: 0.3s; position: relative; }
        .nav-icon.active { color: var(--primary); transform: translateY(-3px); }
        .nav-icon.active::after { content: ''; position: absolute; bottom: -8px; left: 50%; transform: translateX(-50%); width: 5px; height: 5px; background: var(--primary); border-radius: 50%; }

        .modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 2000; justify-content: center; align-items: center; backdrop-filter: blur(5px); }
        .modal-content { background: white; width: 85%; max-width: 340px; border-radius: 25px; padding: 30px; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,0.2); animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        @keyframes popIn { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }

        .page { display: none; padding-bottom: 20px; }
        .page.active { display: block; }
        .text-sec { color: var(--secondary); }
        #security-overlay { display: none; position: fixed; inset: 0; background: #fff; z-index: 20000; flex-direction: column; justify-content: center; align-items: center; }
    </style>
