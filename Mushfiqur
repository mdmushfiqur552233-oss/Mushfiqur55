        .rank-1 .podium-bar { height: 140px; background: #FFD700; box-shadow: 0 10px 20px rgba(255, 215, 0, 0.3); font-size: 30px; }
        .rank-2 .podium-bar { height: 100px; background: #bdc3c7; }
