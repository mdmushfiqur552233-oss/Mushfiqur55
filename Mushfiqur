        /* --- PREMIUM LIGHT THEME VARIABLES --- */
        :root {
            --bg-main: #F2F6F9;
            --card-bg: #FFFFFF;
            --primary: #FF4757;
            --primary-dark: #e8414f;
            --secondary: #2ED573;
            --text-main: #2F3542;
            --text-sub: #747D8C;
            --shadow: 0 10px 30px -5px rgba(255, 71, 87, 0.15);
            --shadow-card: 0 8px 20px rgba(0,0,0,0.05);
            --nav-bg: rgba(255, 255, 255, 0.9);
            --glass-border: rgba(255, 255, 255, 0.5);
        }

        * { 
            margin: 0; padding: 0; box-sizing: border-box; 
            font-family: 'DM Sans', sans-serif; 
            -webkit-tap-highlight-color: transparent; 
            user-select: none; -webkit-user-select: none;
        }
        
        body { 
            background-color: var(--bg-main);
            color: var(--text-main); 
            min-height: 100vh; 
            overflow-x: hidden; 
            padding-bottom: 90px;
            background-image: 
                radial-gradient(circle at 10% 10%, rgba(255, 71, 87, 0.05) 0%, transparent 40%),
                radial-gradient(circle at 90% 90%, rgba(46, 213, 115, 0.05) 0%, transparent 40%);
        }

        /* --- 🍉 WATERMELON LOADER ANIMATION --- */
        #loading-screen { 
            position: fixed; inset: 0; background: #fff; z-index: 9999; 
            display: flex; flex-direction: column; justify-content: center; align-items: center; 
            transition: opacity 0.5s ease; overflow: hidden;
        }

        .knife {
            position: absolute; top: -150px; left: 50%; transform: translateX(-50%);
            font-size: 80px; color: #dfe4ea; text-shadow: 2px 2px 0px #ced6e0;
            z-index: 10;
        }
        .knife i { transform: rotate(135deg); color: #747d8c; }

        .melon-wrapper {
            position: relative; width: 120px; height: 120px;
            display: flex; justify-content: center; align-items: center;
        }
        
        .melon-half {
            width: 60px; height: 120px;
            background: var(--secondary);
            position: relative;
            overflow: hidden;
            transition: transform 0.1s;
        }
        .half-left { border-radius: 60px 0 0 60px; border-right: 1px solid #1e8449; }
        .half-left::after {
            content: ''; position: absolute; top: 5px; left: 5px; right: 0; bottom: 5px;
            background: var(--primary); border-radius: 50px 0 0 50px;
        }
        .half-right { border-radius: 0 60px 60px 0; border-left: 1px solid #1e8449; }
        .half-right::after {
            content: ''; position: absolute; top: 5px; left: 0; right: 5px; bottom: 5px;
            background: var(--primary); border-radius: 0 50px 50px 0;
        }

        .animate-knife-drop { animation: knifeDrop 0.6s cubic-bezier(0.6, 0.04, 0.98, 0.335) forwards; }
        .animate-slow-cut { animation: slowCut 0.8s ease-out forwards; }
        .animate-split-left { animation: splitLeft 0.8s ease-out forwards; }
        .animate-split-right { animation: splitRight 0.8s ease-out forwards; }

        @keyframes knifeDrop {
            0% { top: -150px; opacity: 1; }
            70% { top: 35%; }
            100% { top: 42%; }
        }
        @keyframes slowCut {
            0% { top: 42%; } 
            100% { top: 60%; opacity: 0; }
        }
        @keyframes splitLeft {
            0% { transform: translateX(0) rotate(0); }
            100% { transform: translateX(-60px) rotate(-25deg); opacity: 0; }
        }
        @keyframes splitRight {
            0% { transform: translateX(0) rotate(0); }
            100% { transform: translateX(60px) rotate(25deg); opacity: 0; }
        }

        #main-app { display: none; max-width: 500px; margin: 0 auto; animation: fadeUp 0.8s ease; }
        @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        .header { padding: 25px 25px 10px; display: flex; justify-content: space-between; align-items: center; }
        .user-profile { display: flex; align-items: center; gap: 15px; }
        .avatar-wrap { width: 55px; height: 55px; position: relative; }
        .avatar-img { width: 100%; height: 100%; border-radius: 18px; object-fit: cover; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        .user-details h3 { font-family: 'Fredoka', sans-serif; font-size: 18px; color: var(--text-main); line-height: 1.2; }
        .user-details span { font-size: 12px; color: var(--text-sub); }
        .notif-btn { background: #fff; width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-card); color: var(--primary); font-size: 18px; }

        .card-box {
            background: var(--card-bg);
            border-radius: 24px;
            padding: 20px;
            margin: 15px 25px;
            box-shadow: var(--shadow-card);
            border: 1px solid rgba(0,0,0,0.02);
        }

        .balance-card {
            background: linear-gradient(135deg, var(--primary), #FF6B81);
            color: white;
            text-align: center;
            padding: 30px 20px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 15px 35px -10px rgba(255, 71, 87, 0.4);
        }
        .balance-card::before { content: ''; position: absolute; top: -20px; right: -20px; width: 80px; height: 80px; background: rgba(255,255,255,0.1); border-radius: 50%; }
        .balance-card::after { content: ''; position: absolute; bottom: -30px; left: -10px; width: 100px; height: 100px; background: rgba(255,255,255,0.1); border-radius: 50%; }
        
        .bal-label { font-size: 13px; font-weight: 500; opacity: 0.9; letter-spacing: 1px; text-transform: uppercase; }
        .bal-amount { font-family: 'Fredoka', sans-serif; font-size: 42px; font-weight: 600; margin: 5px 0 15px; }
        
        .action-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 15px; }
        .act-btn {
            background: rgba(255,255,255,0.2); border: none; padding: 12px; border-radius: 14px;
            color: white; font-size: 13px; font-weight: 600; backdrop-filter: blur(5px);
            display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer;
        }
        .act-btn:active { transform: scale(0.96); background: rgba(255,255,255,0.3); }

        .stats-row { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin: 0 25px; }
        .stat-card { background: #fff; padding: 15px; border-radius: 20px; box-shadow: var(--shadow-card); display: flex; flex-direction: column; align-items: center; text-align: center; }
        .stat-icon { width: 40px; height: 40px; border-radius: 50%; background: #F2F6F9; color: var(--secondary); display: flex; align-items: center; justify-content: center; margin-bottom: 8px; font-size: 18px; }
        .stat-val { font-weight: 700; font-size: 18px; color: var(--text-main); font-family: 'Fredoka', sans-serif; }
        .stat-lbl { font-size: 11px; color: var(--text-sub); }

        .btn-primary {
            background: var(--primary); color: white; border: none; width: 100%; padding: 16px;
            border-radius: 16px; font-weight: 700; font-size: 15px; box-shadow: 0 8px 20px -5px rgba(255, 71, 87, 0.4);
            cursor: pointer; transition: 0.2s;
        }
        .btn-primary:active { transform: scale(0.98); box-shadow: none; }

        .section-title { padding: 25px 25px 10px; font-size: 16px; font-weight: 700; color: var(--text-main); display: flex; align-items: center; gap: 8px; }
        .section-title i { color: var(--secondary); }
        
        .task-card {
            background: #fff; margin: 0 25px 15px; padding: 15px; border-radius: 18px;
            display: flex; align-items: center; gap: 15px; box-shadow: var(--shadow-card);
            transition: 0.2s;
        }
        .task-card:active { transform: scale(0.98); }
        .task-img { width: 45px; height: 45px; object-fit: contain; }
        .task-info { flex: 1; }
        .task-name { font-weight: 600; font-size: 14px; margin-bottom: 2px; }
