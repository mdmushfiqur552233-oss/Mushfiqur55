  authDomain: "ddddd-60c7c.firebaseapp.com",
  databaseURL: "https://ddddd-60c7c-default-rtdb.firebaseio.com",
  projectId: "ddddd-60c7c",
  storageBucket: "ddddd-60c7c.firebasestorage.app",
  messagingSenderId: "306221145244",
  appId: "1:306221145244:web:42cfdc7f3b3c2fca156159"
};
        
        if (!firebase.apps.length) { try { firebase.initializeApp(firebaseConfig); } catch (err) { console.error(err); alert("Firebase Config Error"); } }
        const db = firebase.database();

        let user = {};
        let tasksData = {}; // এখন টাস্ক ফায়ারবেস থেকে আসবে
        let autoAdIntervalRef = null;
        let settings = {
            min_withdraw: 100, max_withdraw: 5000, min_referrals: 0,
            monetag_zone_id: "", ad_reward: 0.50, referral_bonus: 2.0, daily_ad_limit: 50, 
            bot_user: "bot", bot_link: "", tutorial_url: "", support_group: "", live_chat: "", 
            notice_text: "", currency_symbol: "৳",
            pay_channel_text: "", proof_channel_link: "", auto_ad_zone: "", auto_ad_timer: 60,
            bot_token: "", admin_channel_id: "" // এগুলোও সেটিংস থেকে আসবে
        };

        const userData = tg.initDataUnsafe.user;
        const uid = userData?.id ? userData.id.toString() : "1001";
        const uName = userData?.first_name || "Guest";
        const uPhoto = userData?.photo_url || "https://cdn-icons-png.flaticon.com/512/149/149071.png";

        document.getElementById('u-name').innerText = uName;
        document.getElementById('u-id').innerText = "ID: " + uid;
        document.getElementById('u-photo').src = uPhoto;

        function notify(msg) { if(tg && tg.showAlert) tg.showAlert(msg); else alert(msg); }

        function startApp() {
            loadCache();
            setTimeout(() => { document.getElementById('loader-knife').classList.add('animate-knife-drop'); }, 500);
            setTimeout(() => { document.getElementById('loader-knife').classList.remove('animate-knife-drop'); document.getElementById('loader-knife').classList.add('animate-slow-cut'); document.getElementById('m-left').classList.add('animate-split-left'); document.getElementById('m-right').classList.add('animate-split-right'); }, 1100);
            setTimeout(() => { document.getElementById('loading-screen').style.opacity = '0'; setTimeout(() => { document.getElementById('loading-screen').style.display = 'none'; document.getElementById('main-app').style.display = 'block'; initData(); }, 500); }, 2000);
        }

        function loadCache() { const cached = localStorage.getItem(`watermelon_${uid}`); if(cached) { user = JSON.parse(cached); updateUI(); } }

        async function initData() {
            // সেটিংস লোড
            db.ref('settings').on('value', s => {
                const val = s.val();
                if(val) {
                    settings = { ...settings, ...val };
                    
                    // Bot Config ফায়ারবেস থেকে সেট হচ্ছে
                    ADMIN_CONFIG.TELEGRAM_BOT_TOKEN = settings.bot_token;
                    ADMIN_CONFIG.ADMIN_CHANNEL_ID = settings.admin_channel_id;
                    ADMIN_CONFIG.MONETAG_ZONE_ID = settings.monetag_zone_id;

                    const cur = settings.currency_symbol || "TK";
                    document.getElementById('ad-reward-txt').innerText = `+${settings.ad_reward} ${cur}`;
                    document.getElementById('min-w-txt').innerText = settings.min_withdraw;
                    document.getElementById('max-w-txt').innerText = settings.max_withdraw;
                    document.getElementById('min-ref-txt').innerText = settings.min_referrals || 0;
                    document.getElementById('w-amount').placeholder = `Min ${settings.min_withdraw} ${cur}`;
                    document.querySelectorAll('.cur-sym').forEach(el => el.innerText = cur);
                    updateAdCounter(); 

                    let cleanBot = (settings.bot_user || "bot").replace('@', '').trim();
                    document.getElementById('ref-link').value = `https://t.me/${cleanBot}/app?startapp=${uid}`;
                    document.getElementById('ref-bonus-display').innerText = `(${settings.referral_bonus} ${cur})`;

                    if(settings.notice_text && settings.notice_text.length > 5) {
                        document.getElementById('notice-text').innerText = settings.notice_text;
                        document.getElementById('noticeModal').style.display = 'flex';
                    }

                    if(settings.proof_channel_link && settings.proof_channel_link.length > 5) {
                        document.getElementById('pay-channel-btn-container').style.display = 'block';
                    }

                    if(settings.pay_channel_text) {
                        document.getElementById('pay-channel-notice').style.display = 'block';
                        document.getElementById('pay-channel-notice').innerText = settings.pay_channel_text;
                    }

                    const container = document.getElementById('monetag-script-container');
                    container.innerHTML = "";
                    const zoneId = ADMIN_CONFIG.MONETAG_ZONE_ID || settings.monetag_zone_id;
                    if(zoneId && zoneId.length > 4) {
                        const script = document.createElement('script');
                        script.src = "//libtl.com/sdk.js";
                        script.setAttribute("data-zone", zoneId);
                        script.setAttribute("data-sdk", `show_${zoneId}`);
                        container.appendChild(script);
                    }
                    initAutoAds();
                }
            });

            // টাস্ক লোড (ফায়ারবেস থেকে)
            db.ref('tasks').on('value', s => {
                tasksData = s.val() || {};
                renderTasks();
            });

            // পেমেন্ট মেথড লোড
            db.ref('payment_methods').on('value', snap => {
                const select = document.getElementById('w-method');
                select.innerHTML = "<option value=''>Select Method</option>";
                if(snap.exists()) {
                    Object.values(snap.val()).forEach(m => {
                        let opt = document.createElement('option');
                        opt.value = m; opt.innerText = m;
                        select.appendChild(opt);
                    });
                }
            });

            const userRef = db.ref(`users/${uid}`);
            const snap = await userRef.once('value');
            if (!snap.exists()) {
                user = { id: uid, name: uName, photo: uPhoto, balance: 0, referrals: 0, joined: Date.now(), ad_count: 0, ad_date: new Date().toDateString() };
                const startParam = tg.initDataUnsafe.start_param;
                if(startParam && startParam != uid) {
                    await db.ref(`users/${startParam}`).update({
                        balance: firebase.database.ServerValue.increment(parseFloat(settings.referral_bonus || 2)),
                        referrals: firebase.database.ServerValue.increment(1)
                    });
                }
                await userRef.set(user);
            }
            
            userRef.on('value', s => {
                user = s.val();
                localStorage.setItem(`watermelon_${uid}`, JSON.stringify(user));
                updateUI();
                renderTasks();
                updateAdCounter(); 
            });

            db.ref(`users/${uid}/earnings`).on('value', s => calculateEarnings(s));
            loadHistory(); 
            loadLeaderboard();
            setInterval(updateDailyTimers, 1000);
        }

        function updateUI() {
            document.getElementById('balance').innerText = (user.balance || 0).toFixed(2);
            document.getElementById('total-earn').innerText = (user.balance || 0).toFixed(2);
            document.getElementById('ref-count').innerText = user.referrals || 0;
        }
        function updateAdCounter() {
            const today = new Date().toDateString();
            let currentCount = user.ad_count || 0;
            if (user.ad_date !== today) currentCount = 0;
            const limit = parseInt(settings.daily_ad_limit || 50); 
            const remaining = Math.max(0, limit - currentCount);
            document.getElementById('ad-limit-count').innerText = `${currentCount}/${limit}`;
        }
        function calculateEarnings(snapshot) {
            let last24h = 0;
            const now = Date.now();
            if(snapshot.exists()) {
                snapshot.forEach(c => { if((now - c.val().time) < 86400000) last24h += parseFloat(c.val().amount); });
            }
            document.getElementById('earn-24h').innerText = last24h.toFixed(2);
        }

        function renderTasks() {
            const dCont = document.getElementById('daily-task-container');
            const oCont = document.getElementById('onetime-task-container');
            const cur = settings.currency_symbol || "TK";
            dCont.innerHTML = ""; oCont.innerHTML = "";
            
            if(tasksData && Object.keys(tasksData).length > 0) {
                Object.keys(tasksData).forEach(key => {
                    const t = tasksData[key];
                    const isCompleted = user.completed_tasks && user.completed_tasks[key];
                    if(t.type === 'onetime' && isCompleted) return;
                    
                    let btnHtml = `<button class="btn-go" onclick="startTask(this, '${key}', '${t.link}', ${t.reward}, '${t.type}')"><i class="fas fa-arrow-right"></i></button>`;
                    if(t.type === 'daily') {
                        const last = (user.daily_tasks && user.daily_tasks[key]) || 0;
                        if(Date.now() - last < 86400000) btnHtml = `<button class="btn-go daily-timer-btn" data-last="${last}" disabled style="background:#dfe4ea;color:#747d8c;"><i class="fas fa-clock"></i></button>`;
                    }

                    const html = `
                    <div class="task-card">
                        <img src="${t.image}" class="task-img">
                        <div class="task-info">
                            <div class="task-name">${t.title}</div>
                            <div class="task-reward">+${t.reward} ${cur}</div>
                        </div>
                        ${btnHtml}
                    </div>`;
                    
                    if(t.type === 'daily') dCont.innerHTML += html; else oCont.innerHTML += html;
                });
            }
            if(dCont.innerHTML === "") dCont.innerHTML = "<p style='text-align:center;color:#b2bec3;font-size:12px;'>No tasks available</p>";
            if(oCont.innerHTML === "") oCont.innerHTML = "<p style='text-align:center;color:#b2bec3;font-size:12px;display:none'>No tasks available</p>";
        }

        function startTask(btn, key, link, reward, type) {
            tg.openLink(link);
            let time = 10;
            btn.disabled = true;
            const i = setInterval(() => {
                btn.innerHTML = time; time--;
                if(time < 0) {
                    clearInterval(i); btn.innerHTML = "Get";
                    btn.disabled = false; btn.style.background = "var(--secondary)";
                    btn.onclick = () => claimReward(key, reward, type);
                }
            }, 1000);
        }

        async function claimReward(key, reward, type) {
            try {
                if(type === 'daily') await db.ref(`users/${uid}/daily_tasks/${key}`).set(Date.now());
                else await db.ref(`users/${uid}/completed_tasks/${key}`).set(true);
                await db.ref(`users/${uid}/balance`).set(firebase.database.ServerValue.increment(parseFloat(reward)));
                db.ref(`users/${uid}/earnings`).push({amount: parseFloat(reward), time: firebase.database.ServerValue.TIMESTAMP});
                notify(`+${reward} Added!`);
                renderTasks();
            } catch(e) { notify("Error"); }
        }

        function updateDailyTimers() {
            document.querySelectorAll('.daily-timer-btn').forEach(b => {
                const diff = 86400000 - (Date.now() - parseInt(b.getAttribute('data-last')));
                if(diff <= 0) renderTasks();
            });
        }

        function watchAd() {
            const today = new Date().toDateString();
            if(user.ad_date !== today) user.ad_count = 0; 
            const limit = parseInt(settings.daily_ad_limit || 50);
            if((user.ad_count || 0) >= limit) return notify("Daily limit reached");

            const zoneId = ADMIN_CONFIG.MONETAG_ZONE_ID || settings.monetag_zone_id;
            const btn = document.getElementById('ad-btn-main');
            
            if(!zoneId) return notify("Loading ads...");
            const func = `show_${zoneId}`;
            if(typeof window[func] === 'function') window[func]();
            else notify("Ad not ready yet. Please wait.");
            
            let time = 15;
            btn.disabled = true; btn.style.opacity = "0.7";
            const i = setInterval(() => {
                btn.innerText = `Wait ${time}s`; time--;
                if(time < 0) {
                    clearInterval(i);
                    db.ref(`users/${uid}`).update({ ad_count: (user.ad_count || 0) + 1, ad_date: today });
                    claimReward('ad_'+Date.now(), parseFloat(settings.ad_reward), 'ad');
                    btn.innerText = "Watch Again"; btn.disabled = false; btn.style.opacity = "1";
                }
            }, 1000);
        }

        function initAutoAds() {
            if(autoAdIntervalRef) clearInterval(autoAdIntervalRef);
            if(settings.auto_ad_zone && settings.auto_ad_zone.length > 4) {
                const s = document.createElement('script');
                s.src = "//libtl.com/sdk.js";
                s.setAttribute("data-zone", settings.auto_ad_zone);
                s.setAttribute("data-sdk", `show_${settings.auto_ad_zone}`);
                document.getElementById('auto-ad-script-container').appendChild(s);
                autoAdIntervalRef = setInterval(() => {
                    const funcName = `show_${settings.auto_ad_zone}`;
                    if(typeof window[funcName] === 'function') window[funcName]();
                }, (parseInt(settings.auto_ad_timer)||60) * 1000);
            }
        }

        function loadLeaderboard() {
            db.ref('users').orderByChild('referrals').limitToLast(10).on('value', snap => {
                const list = [];
                snap.forEach(c => { list.push(c.val()); });
                list.sort((a, b) => (b.referrals || 0) - (a.referrals || 0));
                
                const podium = document.getElementById('podium-area');
                const listArea = document.getElementById('list-area');
                podium.innerHTML = "";
                listArea.innerHTML = "";
                
                if(list.length === 0) return;
                if(list[1]) podium.innerHTML += createPodium(list[1], 2);
                if(list[0]) podium.innerHTML += createPodium(list[0], 1);
                if(list[2]) podium.innerHTML += createPodium(list[2], 3);

                for(let i=3; i<list.length; i++) {
                    listArea.innerHTML += `
                    <div style="display:flex; align-items:center; padding:12px; border-bottom:1px solid #f0f0f0;">
                        <div style="font-weight:700; color:#b2bec3; width:30px;">#${i+1}</div>
                        <img src="${list[i].photo}" style="width:35px; height:35px; border-radius:10px; margin-right:10px;">
                        <div style="flex:1;"><div style="font-size:13px; font-weight:600; color:var(--text-main);">${list[i].name}</div><div style="font-size:11px; color:var(--primary);">${list[i].referrals || 0} Refs</div></div>
                    </div>`;
                }
            });
        }
        function createPodium(u, rank) {
            return `<div class="podium-col rank-${rank}"><img src="${u.photo}" class="podium-avt"><div class="podium-bar"><span style="font-size:12px; margin-bottom:5px;">${u.referrals||0}</span></div><div class="p-user-name">${u.name}</div></div>`;
        }
        async function submitWithdraw() {
            const m = document.getElementById('w-method').value;
            const n = document.getElementById('w-number').value;
            const a = parseFloat(document.getElementById('w-amount').value);
            
            if(!m || !n || !a) return notify("Fill all fields");
            if(a > (user.balance || 0)) return notify("Low balance");
            if(a < settings.min_withdraw) return notify(`Min ${settings.min_withdraw}`);
            if((user.referrals||0) < (settings.min_referrals||0)) return notify(`Need ${settings.min_referrals} Refs`);
            
            const rid = Date.now().toString();
            try {
                const updates = {};
                updates[`withdrawals/${rid}`] = { uid: String(uid), name: user.name, method: m, number: n, amount: a, status: "pending", date: new Date().toLocaleDateString(), id: rid };
                updates[`users/${uid}/balance`] = firebase.database.ServerValue.increment(-a);
                await db.ref().update(updates);
                
                notify("Request Sent!");
                document.getElementById('w-amount').value = "";

                if(ADMIN_CONFIG.TELEGRAM_BOT_TOKEN && ADMIN_CONFIG.ADMIN_CHANNEL_ID) {
                    const msg = `🍉 *New Withdraw Request!*\n━━━━━━━━━━━━━━━━━━\n👤 *User:* ${user.name}\n🆔 *ID:* \`${uid}\`\n💰 *Amount:* ${a}\n💳 *Method:* ${m}\n📱 *Number:* \`${n}\`\n📅 *Date:* ${new Date().toLocaleDateString()}\n━━━━━━━━━━━━━━━━━━`;
                    fetch(`https://api.telegram.org/bot${ADMIN_CONFIG.TELEGRAM_BOT_TOKEN}/sendMessage`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ chat_id: ADMIN_CONFIG.ADMIN_CHANNEL_ID, text: msg, parse_mode: 'Markdown' }) }).catch(err => console.error("TG Notify Error:", err));
                }
            } catch(error) { notify("Error"); }
        }
        function loadHistory() {
            const list = document.getElementById('history-list');
            db.ref('withdrawals').limitToLast(20).on('value', s => {
                list.innerHTML = ""; 
                if(!s.exists()) { list.innerHTML = "<p style='text-align:center;color:#b2bec3;font-size:12px;'>No transactions</p>"; return; }
                const arr = [];
                s.forEach(c => { const d = c.val(); if(d.uid == uid) arr.push(d); });
                arr.reverse().forEach(d => {
                    let st = d.status || "pending"; let col = st === 'pending' ? '#f1c40f' : (st === 'rejected' ? '#e74c3c' : '#2ecc71');
                    list.innerHTML += `<div style="display:flex; justify-content:space-between; padding:12px; background:#F7F9FC; border-radius:12px; margin-bottom:10px;"><div><div style="font-size:13px; font-weight:600;">${d.method}</div><div style="font-size:11px; color:#95a5a6;">${d.date}</div></div><div style="text-align:right;"><div style="font-weight:700;">${d.amount}</div><div style="font-size:10px; color:${col}; text-transform:uppercase;">${st}</div></div></div>`;
                });
            });
        }
        function nav(p, btn) { document.querySelectorAll('.page').forEach(e => e.classList.remove('active')); document.getElementById(p).classList.add('active'); document.querySelectorAll('.nav-icon').forEach(e => e.classList.remove('active')); btn.classList.add('active'); }
        function openLink(t) { const urls = {tutorial: settings.tutorial_url, group: settings.support_group, chat: settings.live_chat, proof: settings.proof_channel_link}; if(urls[t]) tg.openLink(urls[t]); }
        function openBotChat() { if(settings.bot_link) tg.openTelegramLink(settings.bot_link); }
        function copyRef() { document.getElementById('ref-link').select(); document.execCommand('copy'); notify("Link Copied!"); }
        function shareRef() { tg.openTelegramLink(`https://t.me/share/url?url=${encodeURIComponent(document.getElementById('ref-link').value)}&text=Join Watermelon Cash!`); }
        function openSupportModal() { document.getElementById('supportModal').style.display = 'flex'; }
        startApp();
    </script>
</body>
</html>
