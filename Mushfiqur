        .btn-go { background: var(--text-main); color: white; border: none; width: 35px; height: 35px; border-radius: 10px; display: flex; align-items: center; justify-content: center; }

        .input-group { margin-bottom: 15px; }
        .input-label { display: block; font-size: 12px; color: var(--text-sub); margin-bottom: 8px; font-weight: 600; margin-left: 5px; }
        .custom-input {
            width: 100%; background: #F7F9FC; border: none; padding: 18px; border-radius: 16px;
            font-size: 15px; color: var(--text-main); font-weight: 500; outline: none;
        }
        .custom-input:focus { background: #fff; box-shadow: 0 0 0 2px var(--primary); }

        .podium-wrap { display: flex; justify-content: center; align-items: flex-end; gap: 10px; margin: 20px; }
        .podium-col { text-align: center; }
        .podium-avt { width: 50px; height: 50px; border-radius: 50%; border: 3px solid #fff; box-shadow: 0 5px 15px rgba(0,0,0,0.1); margin-bottom: -10px; position: relative; z-index: 2; object-fit: cover; }
        .podium-bar { border-radius: 15px 15px 0 0; padding-top: 15px; width: 80px; color: white; font-weight: 600; font-size: 20px; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 10px; }
        
